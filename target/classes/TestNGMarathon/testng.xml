<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="TestNGMarathon Suite">

    <parameter name="browser" value="Chrome"/>
    <parameter name="url" value="https://login.salesforce.com"/>
    <parameter name="username" value="your_salesforce_username"/>
    <parameter name="password" value="your_salesforce_password"/>

    <test name="Create Account Test">
        <classes>
            <class name="TestNGMarathon.CreateAccount"/>
        </classes>
    </test>

    <test name="Edit Account Test">
        <classes>
            <class name="TestNGMarathon.EditAccount"/>
        </classes>
    </test>

    <test name="Delete Account Test">
        <classes>
            <class name="TestNGMarathon.DeleteAccount"/>
        </classes>
    </test>

</suite>
